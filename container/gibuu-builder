#!/bin/bash
# Check out and build GiBUU source. Assumes fetch-stable has already
# downloaded and unpacked ROOT (root/) and buuinput (gibuu/) into the
# same working directory.
#
# The source refs (branch, tag, or full commit SHA) are meant to be
# passed in via gibuu-builder's caller, e.g. Docker ARG GIBUU_REF/
# ROOTTUPLE_REF, so that a new commit changes the effective command
# and busts exactly this layer's Docker cache -- and nothing upstream
# of it.
#
# Package index: 0=gibuu, 1=roottuple
PKGS=(gibuu roottuple)
PKG_URLS=(
  "https://github.com/kvtsang/GiBUU.git"
  "https://github.com/kvtsang/GiBUU-RootTuple.git"
)
PKG_DESTS=(
  "release"
  "libraries/RootTuple"
)

# Refusing to build against these moving refs by default is the
# production-campaign guard for issue-007 item 3: a bare `download`
# with no ref, or an explicit `main`/`master`/`develop`, must be
# opted into via --allow-branch rather than silently succeeding.
BRANCH_DENYLIST=(main master develop)

die() {
  echo "$@" >&2
  exit 1
}

[[ ${#PKGS[@]} -eq ${#PKG_URLS[@]} && ${#PKGS[@]} -eq ${#PKG_DESTS[@]} ]] \
  || die "Package array length mismatch"

pkg_idx() {
  local name="$1" idx
  for idx in "${!PKGS[@]}"; do
    [[ "${PKGS[$idx]}" == "$name" ]] && echo "$idx" && return 0
  done
  return 1
}

is_full_sha() {
  [[ "$1" =~ ^[0-9a-f]{40}$ ]]
}

is_commit_hash() {
  [[ "$1" =~ ^[0-9a-f]{7,40}$ ]]
}

is_denied_branch() {
  local ref="$1" b
  for b in "${BRANCH_DENYLIST[@]}"; do
    [[ "$ref" == "$b" ]] && return 0
  done
  return 1
}

git_clone() {
  local url="$1"
  local dest="$2"
  local ref="${3:-main}"

  if is_full_sha "$ref"; then
    # GitHub's upload-pack serves a shallow fetch for a full 40-char
    # SHA even though `git clone --branch` only accepts branch/tag
    # names.
    git init -q "$dest" \
      && git -C "$dest" remote add origin "$url" \
      && git -C "$dest" fetch --depth 1 origin "$ref" \
      && git -C "$dest" checkout -q FETCH_HEAD \
      || die "Fail to clone $url at $ref"
  elif is_commit_hash "$ref"; then
    # An abbreviated SHA can't be resolved server-side, so it needs
    # the full history to check out locally -- no shallow fetch.
    git clone -q "$url" "$dest" \
      && git -C "$dest" checkout -q "$ref" \
      || die "Fail to clone $url at $ref"
  else
    git clone --branch "$ref" --depth 1 "$url" "$dest" \
      || die "Fail to clone $url"
  fi
}

help() {
  cat <<-_EOF
$PROGRAM: check out and build GiBUU source

Note
====
Run after fetch-stable has downloaded and unpacked ROOT and buuinput
into the same working directory. The patched GiBUU is installed to
the directory where the script is executed. The script is intended
to be used in container.

Usage
=====
$PROGRAM download [--allow-branch] [package] [ref]
    Checkout GiBUU source (all by default). ref defaults to 'main';
    it may be a branch, a tag, or a commit SHA (7-40 hex chars). A
    full 40-char SHA is fetched shallow; an abbreviated SHA falls
    back to a full clone (GitHub only serves shallow fetches for a
    full SHA).
    Packages: gibuu, roottuple

    Refuses 'main'/'master'/'develop' (including the omitted-ref
    default) unless --allow-branch is passed -- pin to a tag or
    commit SHA for any production build. --allow-branch is an escape
    hatch for local testing against a moving branch.

$PROGRAM version
    Append GiBUU + RootTuple git SHAs to release/version.txt (the file
    the Makefile compiles into GiBUU.x's version string), then mirror
    the result to gibuu/version.txt for runtime extraction.

$PROGRAM build
    Build GiBUU.

$PROGRAM install [DEST]
    Install GiBUU.x to DEST directory.

_EOF
}

download() {
  local allow_branch=0
  while [[ "${1:-}" == --* ]]; do
    case "$1" in
      --allow-branch) allow_branch=1; shift ;;
      *) die "Unknown option: $1" ;;
    esac
  done

  local target="${1:-all}"
  local ref="${2:-main}"
  local targets

  if (( ! allow_branch )) && is_denied_branch "$ref"; then
    die "Refusing to build against moving branch '$ref' without --allow-branch -- pin to a tag or commit SHA for a production build (e.g. 'download $target v1.2.3'), or pass --allow-branch to override for local testing."
  fi

  if [[ "$target" == "all" ]]; then
    targets=("${PKGS[@]}")
  else
    targets=("$target")
  fi

  for name in "${targets[@]}"; do
    local idx
    idx=$(pkg_idx "$name") || die "Unknown package: $name"
    git_clone "${PKG_URLS[$idx]}" "${PKG_DESTS[$idx]}" "$ref"
  done
}

version() {
  [[ -f release/version.txt ]] \
    || die "release/version.txt not found (run 'download gibuu' first)"
  [[ -d gibuu ]] || die "gibuu/ directory not found (run 'fetch-stable unpack' first)"

  if ! grep -q '^GiBUU:' release/version.txt; then
    {
      echo "GiBUU: $(git -C release rev-parse --short HEAD)"
      echo "RootTuple: $(git -C libraries/RootTuple rev-parse --short HEAD)"
    } >> release/version.txt || die "Fail to append SHAs to release/version.txt"
  fi

  cp release/version.txt gibuu/version.txt || die "Fail to copy version.txt"
}

build() {
  source root/bin/thisroot.sh

  cd release || die "release/ directory not found"

  mkdir -p objects/LIB/lib \
  && make -j $(nproc) buildRootTuple \
  && make -j $(nproc) withROOT=1
}

install() {
  DEST="${1:-./}"
  echo "Copying GiBUU.x to $DEST"

  mkdir -p "$DEST" || die "Fail to create $DEST"
  cp release/objects/GiBUU.x "$DEST" || die "Fail to copy GiBUU.x"

  exit 0
}

usage() {
  echo "$PROGRAM download [--allow-branch] [package] [ref] | version | build | install [DEST] | help"
}

PROGRAM="${0##*/}"

case "$1" in
  download) shift; download "$@" ;;
  version)  shift; version "$@" ;;
  build)    shift; build "$@" ;;
  install)  shift; install "$@" ;;
  help|-h)  shift; help ;;
  usage|--usage|-u) shift; usage ;;
  *)        usage; exit 1 ;;
esac
