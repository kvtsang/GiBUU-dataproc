#!/bin/bash
# Check out and build GiBUU source. Assumes fetch-stable has already
# downloaded and unpacked ROOT (root/) and buuinput (gibuu/) into the
# same working directory.
#
# The source refs (branch or tag) are meant to be passed in via
# gibuu-builder's caller, e.g. Docker ARG GIBUU_REF/ROOTTUPLE_REF, so
# that a new commit changes the effective command and busts exactly
# this layer's Docker cache -- and nothing upstream of it.
#
# Package index: 0=gibuu, 1=roottuple
PKGS=(gibuu roottuple)
PKG_URLS=(
  "https://github.com/kvtsang/GiBUU.git"
  "https://github.com/kvtsang/GiBUU-RootTuple.git"
)
PKG_DESTS=(
  "release"
  "libraries/RootTuple"
)

die() {
  echo "$@" >&2
  exit 1
}

[[ ${#PKGS[@]} -eq ${#PKG_URLS[@]} && ${#PKGS[@]} -eq ${#PKG_DESTS[@]} ]] \
  || die "Package array length mismatch"

pkg_idx() {
  local name="$1" idx
  for idx in "${!PKGS[@]}"; do
    [[ "${PKGS[$idx]}" == "$name" ]] && echo "$idx" && return 0
  done
  return 1
}

git_clone() {
  local url="$1"
  local dest="$2"
  local branch="${3:-main}"
  git clone --branch "$branch" --depth 1 "$url" "$dest" \
	  || die "Fail to clone $url"
}

help() {
  cat <<-_EOF
$PROGRAM: check out and build GiBUU source

Note
====
Run after fetch-stable has downloaded and unpacked ROOT and buuinput
into the same working directory. The patched GiBUU is installed to
the directory where the script is executed. The script is intended
to be used in container.

Usage
=====
$PROGRAM download [package] [branch]
    Checkout GiBUU source (all by default). branch defaults to 'main'.
    Packages: gibuu, roottuple

$PROGRAM version
    Write version.txt (GiBUU + RootTuple git SHAs) into gibuu/.

$PROGRAM build
    Build GiBUU.

$PROGRAM install [DEST]
    Install GiBUU.x to DEST directory.

_EOF
}

download() {
  local target="${1:-all}"
  local branch="${2:-main}"
  local targets

  if [[ "$target" == "all" ]]; then
    targets=("${PKGS[@]}")
  else
    targets=("$target")
  fi

  for name in "${targets[@]}"; do
    local idx
    idx=$(pkg_idx "$name") || die "Unknown package: $name"
    git_clone "${PKG_URLS[$idx]}" "${PKG_DESTS[$idx]}" "$branch"
  done
}

version() {
  cd gibuu || die "gibuu/ directory not found (run 'fetch-stable unpack' first)"
  cp ../release/version.txt . || die "Fail to copy version.txt"
  echo "GiBUU: $(git -C ../release rev-parse --short HEAD)" >> version.txt
  echo "RootTuple: $(git -C ../libraries/RootTuple rev-parse --short HEAD)" \
	  >> version.txt
}

build() {
  source root/bin/thisroot.sh

  cd release || die "release/ directory not found"

  mkdir -p objects/LIB/lib \
  && make -j $(nproc) buildRootTuple \
  && make -j $(nproc) withROOT=1
}

install() {
  DEST="${1:-./}"
  echo "Copying GiBUU.x to $DEST"

  mkdir -p "$DEST" || die "Fail to create $DEST"
  cp release/objects/GiBUU.x "$DEST" || die "Fail to copy GiBUU.x"

  exit 0
}

usage() {
  echo "$PROGRAM download [package] [branch] | version | build | install [DEST] | help"
}

PROGRAM="${0##*/}"

case "$1" in
  download) shift; download "$@" ;;
  version)  shift; version "$@" ;;
  build)    shift; build "$@" ;;
  install)  shift; install "$@" ;;
  help|-h)  shift; help ;;
  usage|--usage|-u) shift; usage ;;
  *)        usage; exit 1 ;;
esac
