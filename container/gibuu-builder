#!/bin/bash

root_download_url="https://root.cern.ch/download/\
root_v6.38.04.Linux-ubuntu24.04-x86_64-gcc13.3.tar.gz"
GIBUU_DL="https://github.com/kvtsang/GiBUU.git"
ROOTTUPLE_DL="https://github.com/kvtsang/GiBUU-RootTuple.git"
BUUINPUT_DL="https://gibuu.hepforge.org/downloads?f=buuinput2025.tar.gz"

GIBUU_BRANCH="hepforge"
ROOTTUPLE_BRANCH="hepforge"

die() {
  echo "$@" >&2
  exit 1
}

git_clone() {
  local url="$1"
  local branch="$2"
  local dest="$3"
  git clone --branch "$branch" --depth 1 "$url" "$dest" \
	  || die "Fail to clone $url"
}

help() {
  cat <<-_EOF
$PROGRAM: install GiBUU to a user directory

Note
====
The patched GiBUU is installed to the directory where the script is executed.
The script is intended to be used in container.

Usage
=====
$PROGRAM download
    Download following files to current directory:
    - $root_download_url (wget)
    - $GIBUU_DL → release/ (git clone)
    - $ROOTTUPLE_DL → libraries/RootTuple/ (git clone)
    - $BUUINPUT_DL (wget)

$PROGRAM checksum
    Run md5sum on the downloaded files.

$PROGRAM unpack
    Unzip / untar downlaod files to current directory.

$PROGRAM build
    Build GiBUU.

$PROGRAM install [DEST]
    Install GiBUU.x to DEST directory.

_EOF
}

download() {
  echo "Downloading ..."
  wget -N "$root_download_url" \
  && git_clone "$GIBUU_DL" "$GIBUU_BRANCH" release \
  && git_clone "$ROOTTUPLE_DL" "$ROOTTUPLE_BRANCH" libraries/RootTuple \
  && wget -N --content-disposition "$BUUINPUT_DL"

  [[ $? -ne 0 ]] && die "Fail to download file(s)"
}

checksum() {
  MD5SUM=$(mktemp)
  cat <<-_EOF > $MD5SUM
6d8d5c432008831ddeea38e7b91550ee  buuinput2025.tar.gz
af241e9b4aeb93f6fedfb5d360b31494  root_v6.38.04.Linux-ubuntu24.04-x86_64-gcc13.3.tar.gz
_EOF

  md5sum -c $MD5SUM && rm -f $MD5SUM || die
}

unpack() {
  echo "Unpacking ROOT ..."
  tar zxf $(basename "$root_download_url") || die "Fail to unpack ROOT"

  echo "Setting up GiBUU ..."

  tar zxf buuinput2025.tar.gz

  [[ $? -ne 0 ]] && die "Fail to unpack GiBUU"

  exit 0
}

build() {
  source root/bin/thisroot.sh

  cd release

  mkdir -p objects/LIB/lib \
  && make -j $(nproc) buildRootTuple \
  && make -j $(nproc) withROOT=1 
}

install() {
  DEST=${1:-./}
  echo "Copying GiBUU.x to $DEST"

  mkdir -p $DEST && cp release/objects/GiBUU.x $DEST
  [[ $? -ne 0 ]] && die "Fail to copy GiBUU.x"

  exit 0
}

usage() {
  echo "$PROGRAM downlaod|checksum|unpack|build|install|help [DEST]"
}

PROGRAM="${0##*/}"

case "$1" in
  download) shift; download "$@" ;;
  checksum) shift; checksum "$@" ;;
  unpack)   shift; unpack "$@" ;; 
  build)    shift; build "$@" ;; 
  install)  shift; install "$@" ;;
  help)     shift; help ;;
  *)        usage ;;
esac
